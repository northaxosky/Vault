// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String         @id @default(uuid())
  name         String?
  email        String         @unique
  passwordHash String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  plaidItems   PlaidItem[]    // a user can have many linked banks
  settings     UserSettings?  // a user has one settings record
}

model PlaidItem {
  id              String   @id @default(uuid())
  userId          String
  plaidItemId     String   @unique // Plaid's ID for this bank connection
  accessToken     String            // encrypted with AES-256-GCM
  institutionName String?
  cursor          String?           // bookmark for transaction sync
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accounts        Account[] // a bank connection has many accounts
}

model Account {
  id               String   @id @default(uuid())
  plaidItemId      String
  plaidAccountId   String   @unique // Plaid's ID for this specific account
  name             String            // user-facing name ("My Checking")
  officialName     String?           // bank's official name ("TOTAL CHECKING")
  type             String            // checking, savings, investment, credit
  subtype          String?           // e.g. "401k", "cd", "money market"
  currentBalance   Decimal?          // exact balance right now
  availableBalance Decimal?          // balance available to spend
  currency         String   @default("USD")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  plaidItem        PlaidItem            @relation(fields: [plaidItemId], references: [id], onDelete: Cascade)
  transactions     Transaction[]        // an account has many transactions
  holdings         InvestmentHolding[]  // an investment account has many holdings
}

model Transaction {
  id                 String   @id @default(uuid())
  accountId          String
  plaidTransactionId String   @unique // Plaid's ID for this transaction
  name               String            // description from the bank ("UBER EATS")
  merchantName       String?           // cleaned-up merchant name ("Uber Eats")
  amount             Decimal           // positive = money spent, negative = income
  date               DateTime          // when the transaction occurred
  category           String?           // primary category ("Food and Drink")
  subcategory        String?           // more specific ("Restaurants")
  pending            Boolean  @default(false) // true if not yet settled
  currency           String   @default("USD")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  account            Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
}

model Security {
  id              String              @id @default(uuid())
  plaidSecurityId String              @unique // Plaid's ID for this security
  name            String?                      // "Apple Inc."
  ticker          String?                      // "AAPL" — not all securities have tickers
  type            String?                      // stock, etf, mutual fund, crypto, etc.
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  holdings        InvestmentHolding[]           // many holdings can reference this security
}

model InvestmentHolding {
  id           String   @id @default(uuid())
  accountId    String
  securityId   String
  quantity     Decimal           // number of shares/units
  costBasis    Decimal?          // what the user originally paid
  currentValue Decimal?          // what it's worth now
  currency     String   @default("USD")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  account      Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  security     Security @relation(fields: [securityId], references: [id])

  @@unique([accountId, securityId]) // one holding per security per account
}

model UserSettings {
  id              String   @id @default(uuid())
  userId          String   @unique              // one settings row per user
  accentHue       Int      @default(195)        // 0-360, maps to --accent-hue CSS variable
  currency        String   @default("USD")      // preferred display currency
  dateFormat      String   @default("MM/DD/YYYY")
  emailAlerts     Boolean  @default(true)       // master toggle for notifications
  spendingAlert   Decimal?                      // alert for transactions over this amount
  lowBalanceAlert Decimal?                      // alert when balance drops below this
  weeklyDigest    Boolean  @default(false)      // weekly summary email
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

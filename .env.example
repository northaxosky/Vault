# Database (PostgreSQL)
DATABASE_URL="postgresql://postgres:yourpassword@localhost:5432/vault?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="" # Generate with: openssl rand -base64 32

# Google OAuth (for NextAuth Google provider)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Plaid
PLAID_CLIENT_ID=""
PLAID_SECRET=""                    # sandbox secret
PLAID_SECRET_DEVELOPMENT=""        # development secret (real banks, rate-limited)
PLAID_SECRET_PRODUCTION=""         # production secret
PLAID_ENV="sandbox"                # sandbox | development | production

# Encryption key for Plaid access tokens (AES-256-GCM)
ENCRYPTION_KEY="" # Generate with: openssl rand -hex 32

# Email (Resend)
RESEND_API_KEY=""
EMAIL_FROM="Vault <vault@yourdomain.com>"
